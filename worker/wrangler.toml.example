name = "newapi-checkin-config-relay"
main = "src/entry.mjs"
compatibility_date = "2026-07-11"
workers_dev = true

# Exact, comma-separated browser origins. There is no wildcard matching.
# Add the literal value "null" only if local file:// pages must be allowed.
[vars]
ALLOWED_ORIGINS = "https://your-pages.example, null"
JIANGUO_CONFIG_PATH = "/dav/newapi-config.json"

# Recommended primary storage. Without this binding, the Worker falls back to JianGuoYun WebDAV.
[[kv_namespaces]]
binding = "CONFIG_KV"
id = "replace-with-your-kv-namespace-id"

[observability]
enabled = true
head_sampling_rate = 1

# Configure these as Worker secrets; never put their values in this file:
#   npx wrangler secret put JIANGUO_USERNAME
#   npx wrangler secret put JIANGUO_APP_PASSWORD
#   npx wrangler secret put SYNC_TOKEN
#   npx wrangler secret put ACTIONS_TOKEN
